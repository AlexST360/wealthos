APP_NAME=WealthOS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Frontend URL (para CORS y Sanctum)
FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Base de datos MySQL
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=wealthos
DB_USERNAME=wealthos_user
DB_PASSWORD=wealthos_password

# Redis (caché de precios y sesiones)
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=redis_password
REDIS_PORT=6379

# Caché y sesiones via Redis
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# ── APIs Externas ────────────────────────────────────────────────────────
# Groq API - Obtener en: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# CMF Chile (gratuito) - Registrar en: https://api.cmfchile.cl
CMF_API_KEY=

# Microservicio Python Yahoo Finance (opcional, para mayor confiabilidad)
# Dejar vacío para usar Yahoo Finance directo
YAHOO_FINANCE_SERVICE_URL=

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1
